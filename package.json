{
  "name": "mcp-design-system",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for the MCP server that exposes the FIPS Design System (DS-FIPS) to AI agents.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/FIPS-APP/mcp-design-system.git"
  },
  "scripts": {
    "build": "npm --workspace @fips-app/mcp-design-system run build",
    "dev": "npm --workspace @fips-app/mcp-design-system run dev",
    "smoke": "npm --workspace @fips-app/mcp-design-system exec tsx scripts/smoke.ts",
    "typecheck": "npm --workspace @fips-app/mcp-design-system run typecheck",
    "inspect": "npm --workspace @fips-app/mcp-design-system run inspect"
  },
  "engines": {
    "node": ">=20"
  }
}
