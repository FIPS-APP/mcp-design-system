{
  "name": "@fips-app/mcp-design-system",
  "version": "0.1.0",
  "description": "MCP server exposing the FIPS Design System (DS-FIPS) so any AI agent (Claude Desktop, Cursor, Continue, Cline, ChatGPT) can produce interfaces faithful to the DS — tokens, governed primitives, patterns, and validation tools, all from one source of truth.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "mcp-fips-ds": "./dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "design-system",
    "fips",
    "ds-fips",
    "claude",
    "cursor",
    "continue",
    "cline"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/server.ts",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fips-app/eslint-plugin-ds-governance": "*",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
